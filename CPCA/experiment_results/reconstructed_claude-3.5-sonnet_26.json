{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "s3:ListBucketVersions",
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::singlecomm.recordings",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "",
            "0001*"
          ]
        }
      }
    }
  ]
}